# Rename this file to .env and fill in your keys.

# Required — OpenRouter API key for LLM enrichment and text embeddings
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional — HuggingFace token (only needed if you hit rate limits)
# SmolVLM2-2.2B-Instruct is a public model and does not require authentication
# Get yours at: https://huggingface.co/settings/tokens
# HF_TOKEN=your_huggingface_token_here
